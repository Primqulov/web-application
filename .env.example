# ── Mongo ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ishchibormi

# ── Backend (Go API) ───────────────────────────────────
HTTP_ADDR=:8080
# APP_ENV=production qo'yilganda zaif standart sirlar bilan ishga tushish
# bloklanadi (server xato bilan to'xtaydi). Dev uchun bo'sh/"dev" qoldiring.
APP_ENV=dev
# Klient IP'sini (rate-limit uchun) qanday aniqlashni belgilaydi.
#  - PRODUCTION'da (nginx/caddy/ALB kabi reverse-proxy ortida, TLS bilan):
#    "true" QILING. Aks holda backend har bir so'rov uchun proksi IP'sini ko'radi
#    → BARCHA foydalanuvchilar bitta rate-limit bucket'ni bo'lishadi (haqiqiy
#    userlar 429 oladi, brute-force himoyasi esa buziladi).
#  - LOKAL/to'g'ridan-to'g'ri (proksisiz): "false" qoldiring, aks holda
#    X-Forwarded-For soxtalashtirilib rate-limit chetlab o'tiladi.
# docker-compose (prod yo'li) buni standart "true" qiladi — pastga qarang.
TRUST_PROXY_HEADERS=false
# MUHIM: production'da bu sirlarni kuchli, tasodifiy (>=32 belgi) qiymatlarga
# almashtiring va ikkalasi BIR-BIRIDAN FARQ qilsin. Masalan:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
# Access token muddati (daqiqada). 21600 = 15 kun. Frontend refresh tokenni
# ishlatmagani uchun foydalanuvchi seansi shu qiymat bilan belgilanadi.
JWT_ACCESS_TTL_MIN=21600
JWT_REFRESH_TTL_HRS=720
# Production'da frontend domeningizni yozing, masalan: https://ishchibormi.uz
# (bir nechta bo'lsa vergul bilan). Noto'g'ri bo'lsa brauzer API so'rovlarini
# CORS sababli bloklaydi va sahifa "ishlamayapti"dek ko'rinadi.
CORS_ORIGINS=http://localhost:3000
AVATAR_DIR=/data/avatars
ADMIN_SEED_USER=admin
# Production'da standart paroldan boshqa, kuchli parol qo'ying.
ADMIN_SEED_PASS=Admin123!

# Internal shared secret backend ⇄ bot (HMAC) and bot status callbacks
BOT_SHARED_SECRET=change-me-shared

# OTP behaviour
OTP_TTL_SECONDS=180
OTP_LENGTH=6
# In dev mode the OTP is also returned in the API response body / log line
# so you can complete login without an actual Telegram bot token.
# MUHIM: production'da ALBATTA false bo'lsin — aks holda tasdiqlash kodlari
# API javobida oshkor bo'ladi (akkauntni egallab olish xavfi).
OTP_DEV_RETURN=false

# ── Google Play review login ───────────────────────────
# Play reviewer'i Telegram boti orqali kira olmaydi (uning Telegram hisobi ham,
# O'zbekiston raqami ham yo'q), lekin Google App Access ishlaydigan kredensial
# talab qiladi. Yoqilganda /auth/otp/verify BITTA qo'shimcha kodni qabul qiladi
# va uni BITTA oldindan yaratilgan, cheklangan demo hisobga bog'laydi.
#
# Mexanizm: backend/internal/auth/review.go
# Boshqaruv: docker compose exec backend /app/reviewaccount open|close|status
#
# MUHIM QOIDALAR:
#   - Kod mobil ilovaga HECH QACHON kirmaydi — reviewer uni oddiy 6 xonali OTP
#     maydoniga qo'lda kiritadi. APK'da hech narsa yo'q.
#   - REVIEW_LOGIN_ENABLED review davridan tashqari HAR DOIM false. Deploy
#     pipeline uni har safar false qilib qayta o'rnatadi.
#   - EXPIRES_AT majburiy: oyna o'zi yopiladi. Muddat o'tsa login inert bo'ladi
#     (server yiqilmaydi). Maksimum 30 kun, tavsiya 7 kun.
#   - Tasdiqlangach: ENABLED=false QILING **VA** hisobni bloklang
#     (`reviewaccount close`) — ikkalasi ham shart.
#   - Har submission uchun YANGI kod. Kod hech qachon qayta ishlatilmaydi.
REVIEW_LOGIN_ENABLED=false
REVIEW_LOGIN_CODE=
REVIEW_LOGIN_EXPIRES_AT=
REVIEW_LOGIN_USER_ID=

# ── Telegram bot ───────────────────────────────────────
# Bot displey nomini @BotFather -> /setname orqali "Ish-borni Auth" qilib qo'ying.
# (Bu nom kod orqali emas, BotFather sozlamasidan o'rnatiladi.)
# Bot yuborgan tasdiqlash kodi Markdown `code` formatida bo'lgani uchun
# Telegramda ustiga bossangiz avtomatik nusxalanadi.
TELEGRAM_BOT_TOKEN=
# Bot @username (boshida @ SIZ, faqat nom). Login tugmasidagi t.me havolasi
# shundan quriladi — bo'sh qoldirilsa tugma botga o'tmaydi.
TELEGRAM_BOT_USERNAME=Ishchi_bormi_auth_bot

# ── Taklif / Shikoyat botlari ───────────────────────────
# Foydalanuvchi taklif/shikoyat yuboradigan bot tokeni (@BotFather).
FEEDBACK_BOT_TOKEN=
# Admin javob beradigan bot tokeni (@BotFather).
SUPPORT_BOT_TOKEN=
# Admin bot orqali javob berishga faqat shu raqam tasdiqlangach ruxsat beriladi.
# Namuna faylida haqiqiy shaxsiy raqam turmasin — bu fayl git'ga tushadi.
# Haqiqiy qiymatni faqat serverdagi .env ichiga yozing.
SUPPORT_ADMIN_PHONE=+998XXXXXXXXX

# ── Mobil push (FCM) ───────────────────────────────────
# Firebase service-account JSON fayl yo'li (konteyner ICHIDAGI yo'l).
# Olish: Firebase Console -> Project Settings -> Service accounts ->
# "Generate new private key". Faylni serverda ./secrets/ ostiga qo'ying va
# docker-compose.yml dagi backend volume/environment izohlarini oching.
# Bo'sh qoldirilsa mobil push jimgina o'chiq — API to'liq ishlayveradi.
# MUHIM: bu fayl sir — git'ga qo'shilmaydi (secrets/ .gitignore'da).
FCM_CREDENTIALS_FILE=

# ── AWS S3 (file uploads) ───────────────────────────────
# Bo'sh qoldirilsa, fayl yuklash funksiyalari 503 qaytaradi.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Bo'sh qoldirilsa avtomatik tuziladi: https://<bucket>.s3.<region>.amazonaws.com
AWS_S3_PUBLIC_BASE_URL=

# ── Hisobni o'chirish / saqlash muddati ────────────────
# O'chirilgan hisob "yumshoq o'chirilgan" holatda necha kun turadi. Muddat
# tugagach hisob va unga bog'liq HAMMA yozuv (e'lonlar, arizalar,
# bildirishnomalar, shikoyatlar, fikr-mulohaza, rasmlar, arxivlangan
# telefon/Telegram ID) bazadan butunlay o'chiriladi. Backend buni har 6 soatda
# avtomatik bajaradi — internal/account/retention.go.
#
# DIQQAT: bu raqam foydalanuvchiga aytiladigan muddat bilan BIR XIL bo'lishi
# shart (frontend/lib/retention.ts → /delete-account va /maxfiylik-siyosati).
# Mos kelmasa Google Play siyosati buziladi: kod bajarmaydigan va'da berilgan
# bo'ladi. Bo'sh yoki 0/manfiy qoldirilsa 90 kun qo'llanadi.
ACCOUNT_RETENTION_DAYS=90

# ── Frontend ───────────────────────────────────────────
# MUHIM: bu qiymatlar frontend IMAGE QURILAYOTGANDA kodga yoziladi (build arg).
# Shuning uchun productionda `docker compose up --build` dan OLDIN to'g'ri
# qo'yilishi shart. Foydalanuvchi brauzeri shu manzilga so'rov yuboradi —
# localhost qolib ketsa hech narsa ishlamaydi. Masalan (API shu domenda
# /api proxy bilan bo'lsa):
#   NEXT_PUBLIC_API_BASE=https://ishchibormi.uz
#   NEXT_PUBLIC_WS_BASE=wss://ishchibormi.uz
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_WS_BASE=ws://localhost:8080
